{
  "name": "kibo-tag-aprilcube-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host --mode lan",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host --mode lan",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "cross-env RUN_BROWSER_TESTS=1 playwright test",
    "test:camera:real": "cross-env RUN_REAL_CAMERA=1 RUN_BROWSER_TESTS=1 playwright test e2e/real-camera.spec.ts --headed"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "ml-matrix": "^6.12.2",
    "numopt-js": "^0.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^17.4.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
